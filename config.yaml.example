# Copy to config.yaml and edit paths:
#   cp config.yaml.example config.yaml

# Directory of input images (jpg/png), sorted by filename
images_dir: "/ABSOLUTE/PATH/TO/your-images"

# Feature detector: SIFT | ORB | AKAZE
feature_detector: "SIFT"

# Matcher ratio test (Lowe's ratio); lower = stricter matches
match_ratio: 0.75

# RANSAC reprojection threshold (pixels) for geometric verification
ransac_threshold: 5.0

# Output directory for debug visualizations and point clouds
output_dir: "/ABSOLUTE/PATH/TO/SFM-SLAM/output"

# Optional: limit number of images (0 = all)
max_images: 0

# Save match visualization images
save_match_plots: true
